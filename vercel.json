{
  "functions": {
    "api/*.js": {
      "regions": ["fra1"]
    }
  },
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
        }
      ]
    },
    {
      "source": "/main.dart.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate, proxy-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/tournament-ticket/:action",
      "destination": "/api/tournament-ticket.js?action=:action"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
